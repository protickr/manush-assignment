generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALES_REPRESENTATIVE
  RETAILER
}

model User {
  id            String    @id @default(uuid())
  name          String
  phone         String    @unique
  role          Role      @default(RETAILER)
  passwordHash  String?
  isActive      Boolean   @default(true)
  isMobileValid Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  assignedRetailers Retailer[] // For Sales Representatives

  @@index([phone])
  @@map("users")
}

model Region {
  id        String     @id @default(uuid())
  name      String
  areas     Area[]
  retailers Retailer[]

  @@index([name])
  @@map("regions")
}

model Area {
  id          String      @id @default(uuid())
  name        String
  regionId    String
  region      Region      @relation(fields: [regionId], references: [id])
  territories Territory[]
  retailers   Retailer[]

  @@index([regionId])
  @@map("areas")
}

model Territory {
  id        String     @id @default(uuid())
  name      String
  areaId    String
  area      Area       @relation(fields: [areaId], references: [id])
  retailers Retailer[]

  @@index([areaId])
  @@map("territories")
}

model Distributor {
  id        String     @id @default(uuid())
  name      String
  retailers Retailer[]

  @@index([name])
  @@map("distributors")
}

model Retailer {
  id     String  @id @default(uuid())
  uid    String  @unique
  name   String
  phone  String?
  points Int     @default(0)
  routes String?
  notes  String?

  regionId    String?
  region      Region?    @relation(fields: [regionId], references: [id])
  areaId      String?
  area        Area?      @relation(fields: [areaId], references: [id])
  territoryId String?
  territory   Territory? @relation(fields: [territoryId], references: [id])

  distributorId String?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])

  assignedSrId String?
  assignedSr   User?   @relation(fields: [assignedSrId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedSrId])
  @@index([regionId])
  @@index([areaId])
  @@index([territoryId])
  @@index([distributorId])
  @@index([assignedSrId, regionId])
  @@index([assignedSrId, areaId])
  @@index([assignedSrId, territoryId])
  @@index([assignedSrId, distributorId])
  @@map("retailers")
}
