    {
      "name": "Retailers",
      "item": [
        {
          "name": "Create Retailer (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uid\": \"R99999\",\n  \"name\": \"New Retailer\",\n  \"phone\": \"01999999999\",\n  \"points\": 0,\n  \"routes\": \"Route-1\",\n  \"territoryId\": \"<territory-uuid>\",\n  \"distributorId\": \"<distributor-uuid>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/retailers",
              "host": ["{{baseUrl}}"],
              "path": ["retailers"]
            }
          }
        },
        {
          "name": "List Retailers (paginated + filter)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/retailers?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["retailers"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "regionId", "value": "", "disabled": true },
                { "key": "areaId", "value": "", "disabled": true },
                { "key": "territoryId", "value": "", "disabled": true },
                { "key": "distributorId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "My Assigned Retailers (SR)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/retailers/my?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", "my"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "regionId", "value": "", "disabled": true },
                { "key": "areaId", "value": "", "disabled": true },
                { "key": "territoryId", "value": "", "disabled": true },
                { "key": "distributorId", "value": "", "disabled": true }
              ]
            }
          }
        },
