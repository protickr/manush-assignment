            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"retailerIds\": [\"<retailer-uuid-1>\", \"<retailer-uuid-2>\"],\n  \"srId\": \"<sr-uuid>\"\n}"
