          "name": "Get Retailer by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/retailers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", ":id"],
              "variable": [
                { "key": "id", "value": "", "description": "Retailer UUID" }
              ]
            }
          }
        },
        {
          "name": "Update Retailer (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Retailer\",\n  \"points\": 250\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/retailers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", ":id"],
              "variable": [
                { "key": "id", "value": "", "description": "Retailer UUID" }
              ]
            }
          }
        },
