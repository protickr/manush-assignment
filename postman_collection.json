          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"retailerIds\": [\"<retailer-uuid-1>\", \"<retailer-uuid-2>\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/retailers/bulk-unassign",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", "bulk-unassign"]
            }
          }
        },
        {
          "name": "Import Retailers CSV (Admin)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "CSV file with columns: uid, name, phone, points, routes, notes, region_id, area_id, territory_id, distributor_id"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/retailers/import-csv",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", "import-csv"]
            }
          }
        }
      ]
