            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"points\": 300,\n  \"routes\": \"Route-5\",\n  \"notes\": \"Good retailer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/retailers/:id/sr-update",
              "host": ["{{baseUrl}}"],
              "path": ["retailers", ":id", "sr-update"],
